# ==================================================
# ENV EXAMPLE - Copy file này thành .env và điền giá trị thật
# ==================================================

# --- LOCAL (Docker) ---
# DATABASE_URL="postgresql://postgres:password@localhost:5435/ai_ordering"
# DIRECT_URL="postgresql://postgres:password@localhost:5435/ai_ordering"
# REDIS_URL="redis://localhost:6379"

# --- PRODUCTION (Railway / Supabase / Upstash) ---
# DATABASE_URL  → Supabase Pooler URL (port 6543) — dùng cho runtime queries
# DIRECT_URL    → Supabase Direct URL (port 5432) — dùng cho prisma migrate
DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"
GOOGLE_API_KEY="your-google-api-key"
REDIS_URL="rediss://default:[PASSWORD]@HOST:6379"
