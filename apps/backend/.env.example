# ==================================================
# ENV EXAMPLE — Copy thành .env và điền giá trị thật
# File này được commit lên Git, KHÔNG chứa credentials thật!
# ==================================================

# --- LOCAL (Docker) ---
# Chạy: docker-compose up -d để khởi động PostgreSQL + Redis
DATABASE_URL="postgresql://postgres:password@localhost:5435/ai_ordering"
DIRECT_URL="postgresql://postgres:password@localhost:5435/ai_ordering"
GOOGLE_API_KEY="your-google-api-key-here"
REDIS_URL="redis://localhost:6379"

# --- PRODUCTION (Supabase + Upstash) ---
# Lưu ý: Nếu mật khẩu chứa ký tự đặc biệt (VD: @), hãy encode → %40
#
# DATABASE_URL → Supabase Transaction Pooler (port 6543) — dùng cho runtime
# DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"
#
# DIRECT_URL → Supabase Direct Connection (port 5432) — dùng cho prisma migrate
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres"
#
# GOOGLE_API_KEY="your-google-api-key-here"
#
# REDIS_URL → Upstash Redis (TLS)
# REDIS_URL="rediss://default:[PASSWORD]@[HOST].upstash.io:6379"
